N", "source": "NCBI_entrez"}, {"label": "p120", "source": "NCBI_entrez"}, {"label": "p120(CAS)", "source": "NCBI_entrez"}, {"label": "p120(CTN)", "source": "NCBI_entrez"}, {"label": "catenin delta-1", "source": "NCBI_entrez"}, {"label": "cadherin-associated Src substrate", "source": "NCBI_entrez"}, {"label": "catenin (cadherin-associated protein), delta 1", "source": "NCBI_entrez"}, {"label": "p120 catenin", "source": "NCBI_entrez"}, {"label": "CTNND1", "source": "NCBI_entrez"}], "symbol_synonyms": [{"label": "CTNND1", "source": "uniprot"}, {"label": "KIAA0384", "source": "uniprot"}, {"label": "CAS", "source": "uniprot"}, {"label": "p120(ctn)", "source": "uniprot"}, {"label": "KIAA0384", "source": "HGNC"}, {"label": "p120", "source": "HGNC"}, {"label": "p120cas", "source": "HGNC"}, {"label": "p120ctn", "source": "HGNC"}, {"label": "BCDS2", "source": "NCBI_entrez"}, {"label": "CAS", "source": "NCBI_entrez"}, {"label": "CTNND", "source": "NCBI_entrez"}, {"label": "P120CAS", "source": "NCBI_entrez"}, {"label": "P120CTN", "source": "NCBI_entrez"}, {"label": "p120", "source": "NCBI_entrez"}, {"label": "p120(CAS)", "source": "NCBI_entrez"}, {"label": "p120(CTN)", "source": "NCBI_entrez"}, {"label": "CTNND1", "source": "NCBI_entrez"}], "name_synonyms": [{"label": "Catenin delta-1", "source": "uniprot"}, {"label": "Cadherin-associated Src substrate", "source": "uniprot"}, {"label": "p120 catenin", "source": "uniprot"}, {"label": "p120(cas)", "source": "uniprot"}, {"label": "catenin delta-1", "source": "NCBI_entrez"}, {"label": "cadherin-associated Src substrate", "source": "NCBI_entrez"}, {"label": "catenin (cadherin-associated protein), delta 1", "source": "NCBI_entrez"}, {"label": "p120 catenin", "source": "NCBI_entrez"}], "function_descriptions": ["Key regulator of cell-cell adhesion that associates with and regulates the cell adhesion properties of both C-, E- and N-cadherins, being critical for their surface stability (PubMed:14610055, PubMed:20371349). Promotes locali